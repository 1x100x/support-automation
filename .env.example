# Local development template.
# Do not commit real credentials. Use GitHub Actions secrets for production.

JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=replace-with-local-token

# Optional dashboard link used in the Slack report heading.
JIRA_HELP_DASHBOARD_URL=https://your-domain.atlassian.net/jira/dashboards/10004

# Slack posting is optional locally and enabled in GitHub Actions only when requested.
SLACK_BOT_TOKEN=xoxb-replace-with-local-token
SLACK_REPORT_CHANNEL_ID=C0123456789

# Optional LLM summaries. Keep the key local or in GitHub Actions secrets only.
OPENAI_API_KEY=replace-with-local-openai-key
SUPPORT_USE_LLM_SUMMARIES=true
OPENAI_SUMMARY_MODEL=gpt-4.1-mini

SUPPORT_DASHBOARD_LIMIT=100
SUPPORT_DASHBOARD_RAW=data/help_inbound_raw.json
SUPPORT_DASHBOARD_NORMALIZED=data/support_dashboard_tickets.json
SUPPORT_BUG_REPORT_JSON=data/support_weekly_bug_report.json
SUPPORT_BUG_REPORT_MD=data/support_weekly_bug_report.md
SUPPORT_BUG_REPORT_DASHBOARD=data/support_weekly_bug_report_dashboard.json
SUPPORT_BUG_REPORT_CANVAS=data/support_weekly_bug_report_canvas.md
